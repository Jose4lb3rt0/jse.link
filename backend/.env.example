PORT=5000
BASE_URL=http://localhost:5000
NODE_ENV=development
TRUST_PROXY=false

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379

API_KEY=replace-with-a-strong-key
POST_RATE_LIMIT_PER_MINUTE=10
REDIRECT_RATE_LIMIT_PER_MINUTE=100
DEMO_URL_QUOTA_MAX=50
DEMO_URL_QUOTA_WINDOW_SECONDS=86400
REDIRECT_CACHE_TTL_SECONDS=3600
DEFAULT_URL_TTL_SECONDS=0
MAX_URL_TTL_SECONDS=2592000
DOMAIN_BLACKLIST=localhost,example-malware.test

ALLOWED_ORIGINS=https://sitio.dominio,https://sitio.dominio